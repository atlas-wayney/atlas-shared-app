# Application Configuration
IS_LOCAL=true
APP_ID=atlas_app_identity
API_PREFIX=
ENABLE_DEFAULT_APIS=false

# Database Configuration (AtlasDbSettings)
DB_SETTINGS__HOST_WITH_PORT=localhost:5432
DB_SETTINGS__NAME=atlas
DB_SETTINGS__USER=postgres
DB_SETTINGS__SECRET_PASSWORD=your_password_here
DB_SETTINGS__PROTOCOL=postgresql+asyncpg://
DB_SETTINGS__ECHO=false
DB_SETTINGS__POOL_SIZE=5
DB_SETTINGS__POOL_TIMEOUT=30
DB_SETTINGS__MAX_OVERFLOW=10

# Identity Configuration (AtlasIdentitySettings)
IDENTITY_SETTINGS__BASE_URL=
IDENTITY_SETTINGS__TIMEOUT=30.0
IDENTITY_SETTINGS__INTERNAL_USER_EMAIL_DOMAINS='["qaatlas.com", "atlas.com"]'

# Case Configuration (AtlasCaseSettings)
# Note: case_types is configured in code (dict of SQLModel classes)

# Document Configuration (AtlasDocumentSettings)
DOCUMENT_SETTINGS__BUCKET=
DOCUMENT_SETTINGS__PROJECT_ID=
DOCUMENT_SETTINGS__CREDENTIALS_PATH=
DOCUMENT_SETTINGS__SIGNED_URL_EXPIRATION=3600

# CORS Configuration (AtlasCorsSettings)
CORS_SETTINGS__ALLOW_ORIGIN_REGEX=https://.*\.(atlas|qaatlas)\.com
CORS_SETTINGS__ALLOW_CREDENTIALS=true
CORS_SETTINGS__ALLOW_METHODS='["GET", "POST", "PUT", "DELETE", "OPTIONS"]'
CORS_SETTINGS__ALLOW_HEADERS='["*"]'

# Logging Configuration (AtlasLoggingSettings)
LOGGING_SETTINGS__LEVEL=INFO
LOGGING_SETTINGS__LOG_FILE=logs/app.log
LOGGING_SETTINGS__ROTATION=10 MB
LOGGING_SETTINGS__RETENTION=3 days
LOGGING_SETTINGS__BACKTRACE=true
LOGGING_SETTINGS__DIAGNOSE=true

# Throttling Configuration (AtlasThrottlingSettings)
THROTTLING_SETTINGS__ENABLED=false
THROTTLING_SETTINGS__GLOBAL_LIMIT_PER_SECOND=1000
THROTTLING_SETTINGS__IP_LIMIT_PER_SECOND=100

# Workflow Configuration (AtlasWorkflowSettings)
WORKFLOW_SETTINGS__SECRET_TEMPORAL_API_KEY=
WORKFLOW_SETTINGS__TEMPORAL_NAMESPACE=
WORKFLOW_SETTINGS__TEMPORAL_ADDRESS=
